generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  AGENT
  ADMIN
}

enum ListingStatus {
  DRAFT
  PROCESSING
  PUBLISHED
  PAUSED
  FLAGGED
  REJECTED
  ARCHIVED
}

enum PropertyType {
  APARTMENT
  VILLA
  PENTHOUSE
  OFFICE
  PLOT
}

enum MediaKind {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TravelMode {
  DRIVE
  TRANSIT
  WALK
  CYCLE
}

enum AiOutputKind {
  CHAT_RESPONSE
  LISTING_DRAFT
  IMAGE_ANALYSIS
  TRANSCRIPTION
  RECOMMENDATION
  MARKET_SUMMARY
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ModerationActionType {
  FLAG
  APPROVE
  REJECT
  REMOVE
  SUSPEND_USER
  RESTORE
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  role              UserRole           @default(USER)
  accounts          Account[]
  sessions          Session[]
  listings          Listing[]
  savedListings     SavedListing[]
  savedSearches      SavedSearch[]
  commuteProfiles   CommuteProfile[]
  chatSessions       AiChatSession[]
  generatedOutputs  AiGeneratedOutput[]
  auditLogs          AuditLog[]
  submittedReports  Report[]           @relation("SubmittedReports")
  moderationActions ModerationAction[]  @relation("ModeratorActions")
  claimedGuests     GuestSession[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([role])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GuestSession {
  id             String              @id @default(uuid())
  hashedToken    String              @unique
  claimedById    String?
  claimedBy      User?               @relation(fields: [claimedById], references: [id], onDelete: SetNull)
  draftListings  Listing[]
  chatSessions   AiChatSession[]
  auditLogs      AuditLog[]
  expiresAt      DateTime
  lastSeenAt     DateTime            @default(now())
  aiRequestCount Int                 @default(0)
  riskScore      Int                 @default(0)
  createdAt      DateTime            @default(now())

  @@index([expiresAt])
  @@index([riskScore])
}

model Neighborhood {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  city            String
  state           String
  centroidLat     Decimal?   @db.Decimal(10, 7)
  centroidLng     Decimal?   @db.Decimal(10, 7)
  summary         String?
  properties      Property[]
  marketSnapshots MarketSnapshot[]
  savedSearches   SavedSearch[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([city, name])
}

model Property {
  id             String        @id @default(cuid())
  neighborhoodId String
  neighborhood   Neighborhood  @relation(fields: [neighborhoodId], references: [id], onDelete: Restrict)
  type           PropertyType
  addressLine    String?
  postalCode     String?
  latitude       Decimal?      @db.Decimal(10, 7)
  longitude      Decimal?      @db.Decimal(10, 7)
  bedrooms       Int?
  bathrooms      Int?
  areaSqFt       Int?
  furnishing     String?
  amenities      Json?
  listings       Listing[]
  media          PropertyMedia[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([neighborhoodId, type])
  @@index([latitude, longitude])
}

model Listing {
  id                String              @id @default(cuid())
  ownerId           String?
  owner             User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  guestSessionId    String?
  guestSession      GuestSession?       @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  propertyId        String
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  title             String
  description       String
  price             Decimal             @db.Decimal(14, 2)
  monthlyRent       Decimal?            @db.Decimal(14, 2)
  status            ListingStatus       @default(DRAFT)
  isVerified        Boolean             @default(false)
  publishedAt       DateTime?
  media             PropertyMedia[]
  savedBy           SavedListing[]
  reports           Report[]
  moderationActions ModerationAction[]
  generatedOutputs  AiGeneratedOutput[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([ownerId, status])
  @@index([guestSessionId])
  @@index([propertyId, status])
  @@index([status, publishedAt])
}

model PropertyMedia {
  id               String           @id @default(cuid())
  propertyId       String
  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  listingId        String?
  listing          Listing?         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  kind             MediaKind
  storageKey       String           @unique
  contentType      String
  byteSize         Int
  checksum         String?
  processingStatus ProcessingStatus @default(PENDING)
  processingError  String?
  sortOrder        Int              @default(0)
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([propertyId, kind])
  @@index([listingId, sortOrder])
  @@index([processingStatus])
}

model MarketSnapshot {
  id                String       @id @default(cuid())
  neighborhoodId    String
  neighborhood      Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  periodStart       DateTime
  averageSalePerSqFt Decimal?     @db.Decimal(12, 2)
  medianRent         Decimal?     @db.Decimal(12, 2)
  demandScore        Decimal?     @db.Decimal(5, 2)
  confidence         Decimal?     @db.Decimal(5, 2)
  sampleSize         Int?
  createdAt          DateTime     @default(now())

  @@unique([neighborhoodId, periodStart])
  @@index([periodStart])
}

model CommuteProfile {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  destination     String
  destinationLat  Decimal?     @db.Decimal(10, 7)
  destinationLng  Decimal?     @db.Decimal(10, 7)
  preferredModes  TravelMode[]
  maxMinutes      Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
}

model SavedSearch {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  neighborhoodId String?
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  name           String
  filters        Json
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, updatedAt])
}

model SavedListing {
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([listingId])
}

model AiChatSession {
  id             String              @id @default(cuid())
  userId         String?
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestSessionId String?
  guestSession   GuestSession?       @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  locale         String              @default("en")
  messages       AiChatMessage[]
  outputs        AiGeneratedOutput[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([userId, updatedAt])
  @@index([guestSessionId, updatedAt])
}

model AiChatMessage {
  id        String        @id @default(cuid())
  sessionId String
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  sources   Json?
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt])
}

model AiGeneratedOutput {
  id          String          @id @default(cuid())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  listingId   String?
  listing     Listing?        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  chatSessionId String?
  chatSession AiChatSession?  @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  kind        AiOutputKind
  provider    String?
  model       String?
  inputHash   String?
  output      Json
  confidence  Decimal?        @db.Decimal(5, 2)
  createdAt   DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([listingId, kind])
}

model Report {
  id             String       @id @default(cuid())
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  submittedById  String?
  submittedBy    User?        @relation("SubmittedReports", fields: [submittedById], references: [id], onDelete: SetNull)
  reason         String
  detail         String?
  status         ReportStatus @default(OPEN)
  actions        ModerationAction[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([listingId])
}

model ModerationAction {
  id          String               @id @default(cuid())
  moderatorId String
  moderator   User                 @relation("ModeratorActions", fields: [moderatorId], references: [id], onDelete: Restrict)
  listingId   String?
  listing     Listing?             @relation(fields: [listingId], references: [id], onDelete: SetNull)
  reportId    String?
  report      Report?              @relation(fields: [reportId], references: [id], onDelete: SetNull)
  action      ModerationActionType
  reason      String?
  createdAt   DateTime             @default(now())

  @@index([moderatorId, createdAt])
  @@index([listingId])
  @@index([reportId])
}

model AuditLog {
  id             String        @id @default(cuid())
  actorUserId    String?
  actorUser      User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  guestSessionId String?
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  action         String
  entityType     String?
  entityId       String?
  requestId      String?
  ipHash         String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([actorUserId, createdAt])
  @@index([guestSessionId, createdAt])
  @@index([action, createdAt])
}
